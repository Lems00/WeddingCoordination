# ============================================================================
# EventFlow Pro — Configuration d'environnement
# ============================================================================
# Copier ce fichier en .env.development et .env.production
# NEVER commit les vraies valeurs de secrets

# ============================================================================
# MODE DE PERSISTANCE
# ============================================================================
# false = localStorage (démo locale, données en mémoire, reset au reload)
# true = Cloudflare D1 (production, données persistées en base SQL)
VITE_USE_API=false

# ============================================================================
# URL DE L'API (optionnel, pour production)
# ============================================================================
# En développement : déduit automatiquement (localhost:5173 → localhost:8787)
# En production : URL du déploiement Cloudflare
# VITE_API_URL=https://eventflow.example.com

# ============================================================================
# SECRETS (À CONFIGURER DANS WRANGLER.TOML OU CLOUDFLARE DASHBOARD)
# ============================================================================
# Ces variables ne doivent JAMAIS être commitées en clair
# Elles sont gérées via : npx wrangler pages secret put VARIABLE_NAME

# JWT_SECRET : Clé de signature des tokens JWT (PBKDF2)
# Exemple : openssl rand -base64 32
# À définir dans wrangler.toml : [secrets] ou dashboard Cloudflare
